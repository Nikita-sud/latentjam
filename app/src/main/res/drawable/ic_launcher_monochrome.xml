<?xml version="1.0" encoding="utf-8"?>
<!--
    Themed-icon variant of ic_launcher_foreground. Android 13+ launchers tint this drawable from
    the user's wallpaper-derived theme color, so any fillColor we declare here is overridden.
    Stripping the gradient defs from the colored foreground:
      * Smaller drawable (no <aapt:attr> blocks, no per-path gradient nodes)
      * No noisy AAPT warnings on launchers that try to inspect the original colors
      * Same on-screen result on themed-icon launchers (the launcher recolors anyway)

    Geometry mirrors ic_launcher_foreground.xml exactly so toggling Themed Icons in launcher
    settings keeps the icon in the same position.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Three nodes (filled circles): top-left, mid-right, bottom-center. -->
    <path
        android:pathData="M32,35 a5,5 0 1,0 10,0 a5,5 0 1,0 -10,0 Z"
        android:fillColor="#FFFFFF" />
    <path
        android:pathData="M66,52 a5,5 0 1,0 10,0 a5,5 0 1,0 -10,0 Z"
        android:fillColor="#FFFFFF" />
    <path
        android:pathData="M45,73 a5,5 0 1,0 10,0 a5,5 0 1,0 -10,0 Z"
        android:fillColor="#FFFFFF" />

    <!-- Connecting strokes between the nodes. -->
    <path
        android:pathData="M37,35 C54,35 54,52 71,52"
        android:fillColor="@android:color/transparent"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="3"
        android:strokeLineCap="round" />
    <path
        android:pathData="M71,52 C71,69 62,73 50,73"
        android:fillColor="@android:color/transparent"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="3"
        android:strokeLineCap="round" />

    <!-- Faded latent-lattice path. Kept at 0.5 alpha so the themed tint shows depth. -->
    <path
        android:pathData="M37,35 V73 H50"
        android:fillColor="@android:color/transparent"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="3"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:strokeAlpha="0.5" />
</vector>
