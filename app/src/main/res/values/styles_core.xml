<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Master parent theme -->
    <style name="Theme.LatentJam" parent="Theme.Material3Expressive.DynamicColors.DayNight" />
    <!-- Adds nicer selector attributes not supported on lollipop -->
    <style name="Theme.LatentJam.V23" parent="Theme.LatentJam" />
    <!-- Handles edge-to-edge on other styles variants -->
    <style name="Theme.LatentJam.V27" parent="Theme.LatentJam.V23">
        <item name="android:statusBarColor">@color/chrome_translucent</item>
        <item name="android:navigationBarColor">@color/chrome_translucent</item>
    </style>
    <!-- Adds fully transparent system bars -->
    <style name="Theme.LatentJam.V29" parent="Theme.LatentJam.V27" />
    <!-- Adds an animated splash screen. -->
    <style name="Theme.LatentJam.V31" parent="Theme.LatentJam.V29" />

    <!-- Base theme -->
    <style name="Theme.LatentJam.Base" parent="Theme.LatentJam.V31">

        <!-- Material configuration -->
<!--        <item name="colorOutline">@color/overlay_stroke</item>-->
        <item name="appBarLayoutStyle">@style/Widget.LatentJam.AppBarLayout</item>
        <item name="toolbarStyle">@style/Widget.LatentJam.Toolbar</item>
        <item name="tabStyle">@style/Widget.LatentJam.TabLayout</item>
        <item name="tabSecondaryStyle">@style/Widget.LatentJam.TabLayout.Secondary</item>
        <item name="materialButtonStyle">@style/Widget.LatentJam.Button</item>
        <item name="materialButtonTonalStyle">@style/Widget.LatentJam.Button.TonalButton</item>
        <item name="materialButtonOutlinedStyle">@style/Widget.LatentJam.Button.OutlinedButton</item>
        <item name="materialButtonElevatedStyle">@style/Widget.LatentJam.Button.ElevatedButton</item>
        <item name="borderlessButtonStyle">@style/Widget.LatentJam.Button.TextButton</item>
        <item name="snackbarButtonStyle">@style/Widget.LatentJam.Button.TextButton.Snackbar</item>
        <item name="materialIconButtonStyle">@style/Widget.LatentJam.Button.Icon.Base</item>
        <item name="materialIconButtonOutlinedStyle">
            @style/Widget.Material3Expressive.Button.IconButton.Outlined
        </item>
        <item name="materialIconButtonFilledStyle">
            @style/Widget.Material3Expressive.Button.IconButton.Filled
        </item>
        <item name="materialIconButtonFilledTonalStyle">
            @style/Widget.Material3Expressive.Button.IconButton.Tonal
        </item>
        <item name="materialSplitButtonStyle">@style/Widget.LatentJam.SplitButton</item>
        <item name="materialSplitButtonLeadingFilledStyle">
            @style/Widget.LatentJam.SplitButton.LeadingButton.Filled
        </item>
        <item name="materialSplitButtonLeadingFilledTonalStyle">
            @style/Widget.LatentJam.SplitButton.LeadingButton.Filled.Tonal
        </item>
        <item name="materialSplitButtonIconFilledStyle">
            @style/Widget.LatentJam.SplitButton.IconButton.Filled
        </item>
        <item name="materialSplitButtonIconFilledTonalStyle">
            @style/Widget.LatentJam.SplitButton.IconButton.Filled.Tonal
        </item>
        <item name="materialAlertDialogTheme">@style/Theme.LatentJam.Dialog</item>
        <item name="sliderStyle">@style/Widget.LatentJam.Slider</item>
        <item name="linearProgressIndicatorStyle">@style/Widget.LatentJam.LinearProgressIndicator</item>
        <item name="bottomSheetStyle">@style/Widget.LatentJam.BottomSheet</item>
        <item name="bottomSheetDialogTheme">@style/Widget.LatentJam.BottomSheet.Dialog</item>
        <item name="bottomSheetDragHandleStyle">@style/Widget.LatentJam.BottomSheet.Handle</item>

        <!-- typography -->
        <!-- some of it is non-standard because the default material typography isnt actually
        using emphasized styles when they are supposed to, and it just looks bad. -->
        <item name="textAppearanceDisplayLarge">@style/TextAppearance.LatentJam.DisplayLarge</item>
        <item name="textAppearanceDisplayMedium">@style/TextAppearance.LatentJam.DisplayMedium</item>
        <item name="textAppearanceDisplaySmall">@style/TextAppearance.LatentJam.DisplaySmall</item>
        <item name="textAppearanceDisplayLargeEmphasized">@style/TextAppearance.LatentJam.DisplayLarge.Emphasized</item>
        <item name="textAppearanceDisplayMediumEmphasized">@style/TextAppearance.LatentJam.DisplayMedium.Emphasized</item>
        <item name="textAppearanceDisplaySmallEmphasized">@style/TextAppearance.LatentJam.DisplaySmall.Emphasized</item>

        <item name="textAppearanceHeadlineLarge">@style/TextAppearance.LatentJam.HeadlineLarge</item>
        <item name="textAppearanceHeadlineMedium">@style/TextAppearance.LatentJam.HeadlineMedium</item>
        <item name="textAppearanceHeadlineSmall">@style/TextAppearance.LatentJam.HeadlineSmall</item>
        <item name="textAppearanceHeadlineLargeEmphasized">@style/TextAppearance.LatentJam.HeadlineLarge.Emphasized</item>
        <item name="textAppearanceHeadlineMediumEmphasized">@style/TextAppearance.LatentJam.HeadlineMedium.Emphasized</item>
        <item name="textAppearanceHeadlineSmallEmphasized">@style/TextAppearance.LatentJam.HeadlineSmall.Emphasized</item>

        <item name="textAppearanceTitleLarge">@style/TextAppearance.LatentJam.TitleLarge</item>
        <item name="textAppearanceTitleMedium">@style/TextAppearance.LatentJam.TitleMedium</item>
        <item name="textAppearanceTitleSmall">@style/TextAppearance.LatentJam.TitleSmall</item>
        <item name="textAppearanceTitleLargeEmphasized">@style/TextAppearance.LatentJam.TitleLarge.Emphasized</item>
        <item name="textAppearanceTitleMediumEmphasized">@style/TextAppearance.LatentJam.TitleMedium.Emphasized</item>
        <item name="textAppearanceTitleSmallEmphasized">@style/TextAppearance.LatentJam.TitleSmall.Emphasized</item>

        <item name="textAppearanceLabelLarge">@style/TextAppearance.LatentJam.LabelLarge</item>
        <item name="textAppearanceLabelMedium">@style/TextAppearance.LatentJam.LabelMedium</item>
        <item name="textAppearanceLabelSmall">@style/TextAppearance.LatentJam.LabelSmall</item>
        <item name="textAppearanceLabelLargeEmphasized">@style/TextAppearance.LatentJam.LabelLarge.Emphasized</item>
        <item name="textAppearanceLabelMediumEmphasized">@style/TextAppearance.LatentJam.LabelMedium.Emphasized</item>
        <item name="textAppearanceLabelSmallEmphasized">@style/TextAppearance.LatentJam.LabelSmall.Emphasized</item>

        <item name="textAppearanceBodyLarge">@style/TextAppearance.LatentJam.BodyLarge</item>
        <item name="textAppearanceBodyMedium">@style/TextAppearance.LatentJam.BodyMedium</item>
        <item name="textAppearanceBodySmall">@style/TextAppearance.LatentJam.BodySmall</item>
        <item name="textAppearanceBodyLargeEmphasized">@style/TextAppearance.LatentJam.BodyLarge.Emphasized</item>
        <item name="textAppearanceBodyMediumEmphasized">@style/TextAppearance.LatentJam.BodyMedium.Emphasized</item>
        <item name="textAppearanceBodySmallEmphasized">@style/TextAppearance.LatentJam.BodySmall.Emphasized</item>

        <!-- Fix dumb default android behavior -->
        <item name="android:scrollbars">none</item>
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="colorControlHighlight">@color/sel_compat_ripple</item>
        <item name="colorControlNormal">?attr/colorOnSurfaceVariant</item>
        <item name="colorControlActivated">?attr/colorPrimary</item>

        <!-- Work around hard-coded text highlight colors in the default Material3 theme -->
        <item name="android:textColorHighlight">@color/overlay_text_highlight</item>
        <item name="android:textColorHighlightInverse">@color/overlay_text_highlight_inverse</item>

        <item name="preferenceTheme">@style/PreferenceTheme.LatentJam</item>
        <item name="preferenceStyle">@style/Preference.LatentJam</item>
        <item name="preferenceCategoryStyle">@style/Preference.LatentJam.PreferenceCategory</item>
        <item name="dialogPreferenceStyle">@style/Preference.LatentJam.DialogPreference</item>
        <item name="switchPreferenceCompatStyle">@style/Preference.LatentJam.SwitchPreferenceCompat
        </item>
        <item name="materialButtonGroupStyle">@style/Widget.LatentJam.MaterialButtonGroup</item>
    </style>

    <!-- Make sure blue is the default style instead of material purple -->
    <style name="Theme.LatentJam.App" parent="@style/Theme.LatentJam.Blue" />

    <!--
    Theming widgets is technically possible below Android 12, but I *really* don't care enough
    to bother with it.
    -->
    <style name="Theme.LatentJam.Widget" parent="@style/Theme.LatentJam.Blue" />
</resources>
