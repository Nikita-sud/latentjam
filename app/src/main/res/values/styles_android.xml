<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- ANDROID COMPONENT-SPECIFIC STYLES.-->

    <style name="Theme.LatentJam.Dialog" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="materialAlertDialogTitleTextStyle">@style/TextStyle.LatentJam.Dialog</item>
        <item name="android:checkedTextViewStyle">@style/Widget.LatentJam.Dialog.CheckedTextView</item>
        <item name="materialButtonStyle">@style/Widget.LatentJam.Button</item>
        <item name="materialButtonTonalStyle">@style/Widget.LatentJam.Button.TonalButton</item>
        <item name="materialButtonOutlinedStyle">@style/Widget.LatentJam.Button.OutlinedButton</item>
        <item name="materialButtonElevatedStyle">@style/Widget.LatentJam.Button.ElevatedButton</item>
        <item name="borderlessButtonStyle">@style/Widget.LatentJam.Button.TextButton</item>
        <item name="snackbarButtonStyle">@style/Widget.LatentJam.Button.TextButton.Snackbar</item>
        <item name="materialIconButtonStyle">@style/Widget.LatentJam.Button.Icon.Base</item>
        <item name="materialIconButtonOutlinedStyle">
            @style/Widget.Material3Expressive.Button.IconButton.Outlined
        </item>
        <item name="materialIconButtonFilledStyle">
            @style/Widget.Material3Expressive.Button.IconButton.Filled
        </item>
        <item name="materialIconButtonFilledTonalStyle">
            @style/Widget.Material3Expressive.Button.IconButton.Tonal
        </item>
        <item name="materialSplitButtonStyle">@style/Widget.LatentJam.SplitButton</item>
        <item name="materialSplitButtonLeadingFilledStyle">
            @style/Widget.LatentJam.SplitButton.LeadingButton.Filled
        </item>
        <item name="materialSplitButtonLeadingFilledTonalStyle">
            @style/Widget.LatentJam.SplitButton.LeadingButton.Filled.Tonal
        </item>
        <item name="materialSplitButtonIconFilledStyle">
            @style/Widget.LatentJam.SplitButton.IconButton.Filled
        </item>
        <item name="materialSplitButtonIconFilledTonalStyle">
            @style/Widget.LatentJam.SplitButton.IconButton.Filled.Tonal
        </item>
        <item name="buttonBarButtonStyle">@style/Widget.LatentJam.Button.TextButton.Dialog</item>
        <item name="buttonBarPositiveButtonStyle">@style/Widget.LatentJam.Button.TextButton.Dialog</item>
        <item name="buttonBarNegativeButtonStyle">@style/Widget.LatentJam.Button.TextButton.Dialog</item>
        <item name="buttonBarNeutralButtonStyle">@style/Widget.LatentJam.Button.TextButton.Dialog.Flush</item>
    </style>

    <style name="TextStyle.LatentJam.Dialog" parent="MaterialAlertDialog.MaterialComponents.Title.Text">
        <item name="android:textAppearance">@style/TextAppearance.LatentJam.HeadlineSmall.Emphasized</item>
    </style>

    <!-- The style for the checked text view in the custom dialog -->
    <style name="Widget.LatentJam.Dialog.CheckedTextView" parent="Widget.Material3.CheckedTextView">
        <item name="android:textColor">?android:attr/textColorPrimary</item>
    </style>

    <!-- Dialog style that properly implements dividers in a NestedScrollView -->
    <style name="Widget.LatentJam.Dialog.NestedScrollView" parent="">
        <item name="android:overScrollMode">never</item>
        <item name="android:paddingTop">@dimen/spacing_medium</item>

        <!-- API 23+ specific -->
        <item name="android:scrollIndicators" tools:ignore="NewApi">top|bottom</item>
    </style>

    <style name="PreferenceTheme.LatentJam" parent="@style/PreferenceThemeOverlay">
        <item name="android:layout">@layout/fragment_preferences</item>
    </style>

    <style name="Preference.LatentJam" parent="Preference.Material">
        <item name="allowDividerBelow">false</item>
        <item name="iconSpaceReserved">false</item>
        <item name="android:background">@android:color/black</item>
    </style>

    <style name="Preference.LatentJam.DialogPreference" parent="Preference.DialogPreference.Material">
        <item name="allowDividerBelow">false</item>
        <item name="iconSpaceReserved">false</item>
    </style>

    <style name="Preference.LatentJam.PreferenceCategory" parent="Preference.Category.Material">
        <item name="layout">@layout/item_header</item>
        <item name="allowDividerBelow">false</item>
        <item name="iconSpaceReserved">false</item>
    </style>

    <style name="Preference.LatentJam.SwitchPreferenceCompat" parent="Preference.SwitchPreferenceCompat.Material">
        <item name="widgetLayout">@layout/view_preference_switch</item>
        <item name="allowDividerBelow">false</item>
        <item name="iconSpaceReserved">false</item>
    </style>

    <!-- Widget TextView that mimics the main LatentJam Primary/Secondary TextViews. -->
    <style name="Widget.LatentJam.TextView.AppWidget" parent="Widget.LatentJam.TextView.Base">
        <item name="android:singleLine">true</item>
        <item name="android:ellipsize">end</item>
    </style>

    <!-- Widget TextView that mimics the main LatentJam Primary TextView -->
    <style name="Widget.LatentJam.TextView.Primary.AppWidget" parent="Widget.LatentJam.TextView.AppWidget">
        <item name="android:textAppearance">@style/TextAppearance.Material3.TitleMedium</item>
    </style>

    <!-- Widget TextView that mimics the main LatentJam Secondary TextView -->
    <style name="Widget.LatentJam.TextView.Secondary.AppWidget" parent="Widget.LatentJam.TextView.AppWidget">
        <item name="android:textColor">?android:attr/textColorSecondary</item>
        <item name="android:textAppearance">@style/TextAppearance.Material3.BodyMedium</item>
    </style>

    <!-- A variant of PlaybackButton that plays along with AppWidget restrictions. -->
    <style name="Widget.LatentJam.MaterialButton.AppWidget" parent="Widget.AppCompat.Button.Borderless">
        <item name="android:minHeight">@dimen/size_touchable_small</item>
        <item name="android:background">?android:attr/selectableItemBackgroundBorderless</item>
    </style>

    <!-- A variant of button that emulates a FAB-ish button that plays along with widget restrictions -->
    <style name="Widget.LatentJam.MaterialButton.AppWidget.PlayPause" parent="Widget.AppCompat.Button.Borderless">
        <item name="android:minWidth">@dimen/size_touchable_small</item>
        <item name="android:background">@drawable/ui_remote_fab_container_paused</item>
        <item name="android:tint">?attr/colorOnPrimary</item>
    </style>
</resources>
