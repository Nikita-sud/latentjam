    <style name="Widget.LatentJam.SplitButton" parent="Widget.Material3.MaterialSplitButton" />

    <style name="Widget.LatentJam.SplitButton.LeadingButton.Filled" parent="Widget.Material3.SplitButton.LeadingButton.Filled">
        <item name="labelTextAppearance">?attr/textAppearanceLabelLargeEmphasized</item>
        <item name="android:textAppearance">?attr/textAppearanceLabelLargeEmphasized</item>
    </style>

    <style name="Widget.LatentJam.SplitButton.LeadingButton.Filled.Tonal" parent="Widget.Material3.SplitButton.LeadingButton.Filled.Tonal">
        <item name="labelTextAppearance">?attr/textAppearanceLabelLargeEmphasized</item>
        <item name="android:textAppearance">?attr/textAppearanceLabelLargeEmphasized</item>
    </style>

    <style name="Widget.LatentJam.SplitButton.IconButton.Filled" parent="Widget.Material3.SplitButton.IconButton.Filled" />

    <style name="Widget.LatentJam.SplitButton.IconButton.Filled.Tonal" parent="Widget.Material3.SplitButton.IconButton.Filled.Tonal" />

    <style name="Widget.LatentJam.Button.Primary" parent="Widget.LatentJam.Button">
        <item name="iconGravity">textStart</item>
        <item name="iconSize">@dimen/size_icon_small</item>
    </style>

    <style name="Widget.LatentJam.Button.Secondary" parent="Widget.LatentJam.Button.TonalButton">
        <item name="iconGravity">textStart</item>
        <item name="iconSize">@dimen/size_icon_small</item>
    </style>

    <style name="Widget.LatentJam.Button.Icon.Base" parent="Widget.Material3Expressive.Button.IconButton">
        <item name="materialThemeOverlay">@style/ThemeOverlay.LatentJam.UncheckableIconButton</item>
    </style>

    <style name="ThemeOverlay.LatentJam.UncheckableIconButton" parent="">
        <item name="colorContainer">@android:color/transparent</item>
        <item name="colorOnContainer">?attr/colorOnSurfaceVariant</item>
    </style>

    <style name="Widget.LatentJam.Button.Icon.Small" parent="Widget.LatentJam.Button.Icon.Base">
        <item name="iconSize">@dimen/size_icon_small</item>
        <item name="android:minWidth">@dimen/size_touchable_small</item>
        <item name="android:minHeight">@dimen/size_touchable_small</item>
        <item name="android:insetTop">@dimen/spacing_tiny</item>
        <item name="android:insetBottom">@dimen/spacing_tiny</item>
        <item name="android:insetLeft">@dimen/spacing_tiny</item>
        <item name="android:insetRight">@dimen/spacing_tiny</item>
        <item name="android:paddingStart">@dimen/spacing_small</item>
        <item name="android:paddingEnd">@dimen/spacing_small</item>
        <item name="android:paddingTop">@dimen/spacing_small</item>
        <item name="android:paddingBottom">@dimen/spacing_small</item>
        <!-- Intentional to prevent button from spamming the log console -->
        <item name="iconTint" tools:ignore="PrivateResource">@color/m3_text_button_foreground_color_selector</item>
    </style>

    <style name="Widget.LatentJam.Button.Icon.Medium" parent="Widget.Material3Expressive.Button.IconButton.Outlined">
        <item name="iconSize">@dimen/size_icon_medium</item>
        <item name="android:minWidth">@dimen/size_touchable_small</item>
