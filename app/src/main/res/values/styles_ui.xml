    </style>

    <style name="Widget.LatentJam.Button.TextButton.Dialog" parent="Widget.Material3Expressive.Button.TextButton.Dialog">
        <item name="labelTextAppearance">?attr/textAppearanceLabelLargeEmphasized</item>
