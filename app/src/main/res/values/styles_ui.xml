    <style name="Widget.LatentJam.Button.Playback.Skip" parent="Widget.Material3Expressive.Button.IconButton.Tonal" />

    <style name="Widget.LatentJam.Button.Playback.PlayPause" parent="Widget.Material3Expressive.Button.IconButton.Tonal">
