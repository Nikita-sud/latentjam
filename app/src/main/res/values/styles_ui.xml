    <style name="Widget.LatentJam.Button.Playback.More" parent="Widget.LatentJam.Button.Icon.Base" />

    <style name="Widget.LatentJam.Button.Playback.Toggle" parent="Widget.Material3Expressive.Button.IconButton.Outlined">
        <item name="android:checkable">true</item>
        <item name="toggleCheckedStateOnClick">false</item>
        <item name="iconTint">@color/sel_checkable_icon</item>
        <item name="strokeColor">@color/sel_checkable_outline</item>
        <item name="backgroundTint">?attr/colorSurfaceContainerLow</item>
