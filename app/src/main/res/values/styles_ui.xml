    <style name="ThemeOverlay.LatentJam.IconButton.Palette.Secondary" parent="">
        <item name="colorContainer">?attr/colorSecondaryContainer</item>
        <item name="colorOnContainer">?attr/colorOnSecondaryContainer</item>
    </style>

    <style name="ThemeOverlay.LatentJam.IconButton.Style.Small.Primary" parent="">
        <item name="materialIconButtonStyle">@style/Widget.LatentJam.Button.Icon.Small.Primary</item>
    </style>

    <style name="ThemeOverlay.LatentJam.IconButton.Style.Small.Secondary" parent="">
        <item name="materialIconButtonStyle">@style/Widget.LatentJam.Button.Icon.Small.Secondary</item>
    </style>

    <style name="Widget.LatentJam.Button.PlayPause" parent="Widget.Material3Expressive.Button.IconButton">
        <item name="android:checkable">true</item>
    </style>

    <style name="Widget.LatentJam.Button.PlayPause.Secondary" parent="Widget.Material3Expressive.Button.IconButton">
        <item name="backgroundTint">?attr/colorSecondary</item>
