<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingHorizontal="24dp"
    android:paddingTop="20dp"
    android:paddingBottom="8dp">

    <TextView
        android:id="@+id/edit_meta_song_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:textAppearance="?textAppearanceBodyMedium"
        android:textColor="?colorOnSurfaceVariant"
        android:ellipsize="end"
        android:maxLines="2"
        tools:text="Queen — Bohemian Rhapsody"
        xmlns:tools="http://schemas.android.com/tools" />

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/edit_meta_genre_layout"
        style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:hint="@string/lbl_metadata_genre">

        <com.google.android.material.textfield.MaterialAutoCompleteTextView
            android:id="@+id/edit_meta_genre"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="text|textCapWords"
            android:imeOptions="actionNext"
            android:completionThreshold="1" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/edit_meta_artist_layout"
        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:hint="@string/lbl_metadata_artist">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/edit_meta_artist"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="text"
            android:imeOptions="actionNext"
            android:singleLine="true" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/edit_meta_year_layout"
        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:hint="@string/lbl_metadata_year">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/edit_meta_year"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="number"
            android:imeOptions="actionDone"
            android:singleLine="true"
            android:maxLength="4" />
    </com.google.android.material.textfield.TextInputLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="4dp"
        android:text="@string/info_metadata_override_hint"
        android:textAppearance="?textAppearanceBodySmall"
        android:textColor="?colorOnSurfaceVariant" />
</LinearLayout>
